# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to GitHub — it's in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Flask secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# OpenAI API key — get one at https://platform.openai.com/api-keys
# Leave blank (or remove) to run in Demo Mode with simulated AI responses.
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────────────────

# Force demo mode even when OPENAI_API_KEY is set (useful for local dev)
# DEMO_MODE=true

# PostgreSQL connection string — defaults to SQLite if unset.
# (Render.com sets this automatically when you add a Postgres database.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
