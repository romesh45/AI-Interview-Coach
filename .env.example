# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to GitHub — it's in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Flask secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# AI provider selection: auto | gemini | openai
# - auto picks gemini if GEMINI_API_KEY exists, otherwise openai
AI_PROVIDER=auto

# Gemini API key (recommended for your setup)
# Get one at: https://aistudio.google.com/app/apikey
# Leave blank to run in Demo Mode (if OPENAI_API_KEY is also blank)
GEMINI_API_KEY=

# Optional Gemini model (default is gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional OpenAI API key — used only if provider resolves to OpenAI
OPENAI_API_KEY=

# Optional OpenAI model (default is gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── Optional ──────────────────────────────────────────────────────────────────

# Force demo mode even when a provider key is set (useful for local dev)
# DEMO_MODE=true

# PostgreSQL connection string — defaults to SQLite if unset.
# (Render.com sets this automatically when you add a Postgres database.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
